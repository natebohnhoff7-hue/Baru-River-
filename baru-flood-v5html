//  IMN STATIONS (via Claude API proxy)
// ══════════════════════════════════════════════════════
// ══════════════════════════════════════════════════════
//  MOON DISC RENDERER
// ══════════════════════════════════════════════════════
function drawMoon(phase) {
  const canvas = document.getElementById('moon-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const cx = W/2, cy = H/2, r = W/2 - 2;
  ctx.clearRect(0, 0, W, H);

  // Illumination fraction 0→1 (new→full→new)
  const age   = lunarAge(new Date());
  const illum = 0.5 * (1 - Math.cos(2 * Math.PI * age / LUNAR_CYCLE));
  const waxing = age < LUNAR_CYCLE / 2;

  // ── Draw using path clipping technique ──
  // Step 1: dark disc background
  ctx.beginPath();
  ctx.arc(cx, cy, r, 0, 2 * Math.PI);
  ctx.fillStyle = '#0e1a14';
  ctx.fill();

  // Step 2: clip to circle
  ctx.save();
  ctx.beginPath();
  ctx.arc(cx, cy, r, 0, 2 * Math.PI);
  ctx.clip();

  // Step 3: lit colour fills the disc from the appropriate side
  // We use two shapes: a semicircle + an ellipse
  const litColor  = '#f5ead8';
  const darkColor = '#0e1a14';

  // Terminator ellipse x-radius: goes from r (new, fully dark) → 0 (quarter) → r (full, fully lit)
  // illum 0 = new (no light), 0.5 = quarter, 1.0 = full
  const ex = r * Math.abs(2 * illum - 1); // 0 at quarter, r at new/full

  if (waxing) {
    // Waxing: light on right side, dark on left
    // Fill right semicircle lit
    ctx.beginPath();
    ctx.moveTo(cx, cy - r);
    ctx.arc(cx, cy, r, -Math.PI/2, Math.PI/2);
    ctx.closePath();
    ctx.fillStyle = litColor;
    ctx.fill();
    // illum < 0.5: overlay dark ellipse on right to narrow the crescent
    // illum > 0.5: overlay lit ellipse on left to widen the gibbous
    ctx.beginPath();
    ctx.ellipse(cx, cy, ex, r, 0, -Math.PI/2, Math.PI/2, false);
    ctx.closePath();
    ctx.fillStyle = illum < 0.5 ? darkColor : litColor;
    ctx.fill();
  } else {
    // Waning: light on left side, dark on right
    ctx.beginPath();
    ctx.moveTo(cx, cy - r);
    ctx.arc(cx, cy, r, Math.PI/2, -Math.PI/2);
    ctx.closePath();
    ctx.fillStyle = litColor;
    ctx.fill();
    ctx.beginPath();
    ctx.ellipse(cx, cy, ex, r, 0, Math.PI/2, -Math.PI/2, false);
    ctx.closePath();
    ctx.fillStyle = illum < 0.5 ? darkColor : litColor;
    ctx.fill();
  }

  ctx.restore();

  // Step 4: subtle glow rim
  ctx.beginPath();
  ctx.arc(cx, cy, r, 0, 2 * Math.PI);
  ctx.strokeStyle = 'rgba(240,232,200,0.18)';
  ctx.lineWidth = 1.5;
  ctx.stroke();

  // Step 5: update labels
  document.getElementById('ov-lunar-name').textContent = phase.name;
  document.getElementById('ov-lunar-pct').textContent  = Math.round(illum * 100) + '% lit';
}

