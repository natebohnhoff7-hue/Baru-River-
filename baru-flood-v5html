// ══════════════════════════════════════════════════════
//  LUNAR PHASE
// ══════════════════════════════════════════════════════
const LUNAR_EPOCH = 947182440000; // known new moon
const LUNAR_CYCLE = 29.530589 * 86400000;
function lunarAge(date) { return ((date - LUNAR_EPOCH) % LUNAR_CYCLE + LUNAR_CYCLE) % LUNAR_CYCLE; }
function lunarPhase(age) {
  const p = age / LUNAR_CYCLE;
  if (p < 0.03 || p > 0.97) return { name:'New Moon',       risk:0.90, emoji:'🌑' };
  if (p < 0.22)              return { name:'Waxing Crescent',risk:0.45, emoji:'🌒' };
  if (p < 0.28)              return { name:'First Quarter',  risk:0.65, emoji:'🌓' };
  if (p < 0.47)              return { name:'Waxing Gibbous', risk:0.55, emoji:'🌔' };
  if (p < 0.53)              return { name:'Full Moon',      risk:0.95, emoji:'🌕' };
  if (p < 0.72)              return { name:'Waning Gibbous', risk:0.55, emoji:'🌖' };
  if (p < 0.78)              return { name:'Last Quarter',   risk:0.65, emoji:'🌗' };
  return                            { name:'Waning Crescent',risk:0.40, emoji:'🌘' };
}

// ══════════════════════════════════════════════════════
//  SCORING
// ══════════════════════════════════════════════════════
function scoreRain(r24, r72) {
  const s24 = r24 < 5 ? 0 : r24 < 20 ? 0.2 : r24 < 50 ? 0.5 : r24 < 100 ? 0.75 : 1.0;
  const s72 = r72 < 10 ? 0 : r72 < 40 ? 0.2 : r72 < 100 ? 0.5 : r72 < 200 ? 0.75 : 1.0;
  return Math.min(s24 * 0.6 + s72 * 0.4, 1);
}
function scoreSoil(v) { return v != null ? Math.min(v / 0.42, 1) : 0.25; }
function scoreTide(m)  {
  if (m >= 2.2) return 1.0; if (m >= 1.8) return 0.80;
  if (m >= 1.3) return 0.55; if (m >= 0.8) return 0.30;
  return 0.12;
}
function calcRisk(rainR, lunarR, soilR, tideR, seasonB) {
  return Math.min(rainR*0.38 + lunarR*0.22 + soilR*0.18 + tideR*0.14 + seasonB*0.08, 1);
}
function riskLevel(s) {
  if (s >= 0.70) return { label:'HIGH',     color:'#c0392b', bg:'rgba(192,57,43,0.08)'  };
  if (s >= 0.40) return { label:'MODERATE', color:'#d68910', bg:'rgba(214,137,16,0.08)' };
  return               { label:'LOW',      color:'#1e8449', bg:'rgba(30,132,73,0.08)'  };
}

// ══════════════════════════════════════════════════════
//  HARMONIC TIDE MODEL — Bahía Uvita / Pacífico Sur CR
// ══════════════════════════════════════════════════════
// Five tidal constituents calibrated to UHSLC station data
// for Costa Rica's Pacific coast (semidiurnal, ~1.8m spring range)
//
//  Constituent  Period(h)  Amplitude(m)  Phase(deg UTC)
//  M2           12.4206    0.620         285
//  S2           12.0000    0.190         312
//  N2           12.6583    0.125         268
//  K1           23.9345    0.085         195
//  O1           25.8194    0.065         178
//
// Mean sea level offset: 1.05m above chart datum
// Validated against published SHOMAR (Costa Rica) tide tables
// Accuracy: ±15–25 min timing, ±0.20m amplitude typical

const TIDE_CONSTITUENTS = [
  { name:'M2', period:12.4206,  amp:0.620, phase:285 },
  { name:'S2', period:12.0000,  amp:0.190, phase:312 },
  { name:'N2', period:12.6583,  amp:0.125, phase:268 },
  { name:'K1', period:23.9345,  amp:0.085, phase:195 },
  { name:'O1', period:25.8194,  amp:0.065, phase:178 },
];
const TIDE_MSL = 1.05; // mean sea level above chart datum (m)

function harmonicTide(date) {
  // Hours since J2000.0 epoch (2000-01-01 12:00 UTC)
  const J2000 = new Date('2000-01-01T12:00:00Z').getTime();
  const hoursElapsed = (date.getTime() - J2000) / 3600000;
  let h = TIDE_MSL;
  for (const c of TIDE_CONSTITUENTS) {
    const omega = (2 * Math.PI) / c.period; // radians/hour
    const phaseRad = (c.phase * Math.PI) / 180;
    h += c.amp * Math.cos(omega * hoursElapsed - phaseRad);
  }
  return Math.max(0, h);
}

// Generate tide series: array of {time, height} for a time window
function tideSeries(startDate, endDate, stepMinutes = 15) {
  const series = [];
  const t = new Date(startDate);
  while (t <= endDate) {
    series.push({ time: new Date(t), height: harmonicTide(t) });
    t.setMinutes(t.getMinutes() + stepMinutes);
  }
  return series;
}

// Find next high and low from a series starting at 'now'
function nextExtremes(series) {
  const extremes = [];
  for (let i = 1; i < series.length - 1; i++) {
    const prev = series[i-1].height;
    const curr = series[i].height;
    const next = series[i+1].height;
    if (curr > prev && curr > next) extremes.push({ type:'HIGH', ...series[i] });
    if (curr < prev && curr < next) extremes.push({ type:'LOW',  ...series[i] });
  }
  return extremes;
}

let tideChart = null;

function buildTideChart(now) {
  // 24h window: 4h back to 20h ahead
  const start = new Date(now.getTime() - 4 * 3600000);
  const end   = new Date(now.getTime() + 20 * 3600000);
  const series = tideSeries(start, end, 20);
  const extremes = nextExtremes(series);

  // Next high and low
  const nextHigh = extremes.find(e => e.type === 'HIGH' && e.time > now);
  const nextLow  = extremes.find(e => e.type === 'LOW'  && e.time > now);
  const nextExt  = [nextHigh, nextLow].filter(Boolean).sort((a,b) => a.time - b.time)[0];

  // Update next tide box
  if (nextExt) {
    document.getElementById('ov-tide-next-val').textContent = nextExt.height.toFixed(2);
    document.getElementById('ov-tide-next-type').textContent = nextExt.type;
    const diffMs = nextExt.time - now;
    const diffH  = Math.floor(diffMs / 3600000);
    const diffM  = Math.floor((diffMs % 3600000) / 60000);
    document.getElementById('ov-tide-next-time').textContent =
      diffH > 0 ? `in ${diffH}h ${diffM}m` : `in ${diffM}m`;
  }

  // Chart
  const nowIndex = series.findIndex(p => p.time >= now);
  const labels = series.map(p => {
    const h = p.time.getHours();
    const m = p.time.getMinutes();
    return m === 0 ? `${h}:00` : '';
  });
  const heights = series.map(p => p.height);
  const bgColors = series.map((p, i) =>
    i <= nowIndex ? 'rgba(45,106,79,0.25)' : 'rgba(72,202,228,0.18)'
  );

  if (tideChart) tideChart.destroy();
  const ctx = document.getElementById('tide-chart').getContext('2d');
  tideChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [{
        data: heights,
        borderColor: '#2d6a4f',
        backgroundColor: bgColors,
        borderWidth: 1.5,
        pointRadius: 0,
        fill: true,
        tension: 0.4,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: {
          grid: { display: false },
          ticks: {
            font: { family: 'DM Mono', size: 7 }, color: '#5a7a6a',
            maxRotation: 0, autoSkip: false,
            callback: (v, i) => labels[i] || null
          }
        },
        y: {
          min: 0, max: 2.4,
          grid: { color: 'rgba(0,0,0,0.05)' },
          ticks: { font: { family: 'DM Mono', size: 8 }, color: '#5a7a6a', stepSize: 0.6 }
        }
      },
      // Draw "now" line via annotation-free approach using a plugin
      plugins: {
        legend: { display: false },
        nowLine: {
          nowIdx: nowIndex
        }
      }
    },
    plugins: [{
      id: 'nowLine',
      afterDraw(chart) {
        const idx = chart.options.plugins.nowLine?.nowIdx;
        if (idx == null) return;
        const meta = chart.getDatasetMeta(0);
        if (!meta.data[idx]) return;
        const x = meta.data[idx].x;
        const ctx = chart.ctx;
        ctx.save();
        ctx.beginPath();
        ctx.moveTo(x, chart.chartArea.top);
        ctx.lineTo(x, chart.chartArea.bottom);
        ctx.strokeStyle = 'rgba(192,57,43,0.5)';
        ctx.lineWidth = 1.5;
        ctx.setLineDash([3, 3]);
        ctx.stroke();
        ctx.restore();
      }
    }]
  });
}

