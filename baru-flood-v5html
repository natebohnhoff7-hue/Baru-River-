  const results = await Promise.all(
    Object.entries(COORDS).map(async ([key, c]) => {
      try {
        const url = `https://api.open-meteo.com/v1/forecast?latitude=${c.lat}&longitude=${c.lon}` +
          `&daily=precipitation_sum&past_days=3&forecast_days=1&timezone=America%2FCosta_Rica`;
        const r = await fetch(url);
        const d = await r.json();
        const today = d.daily?.precipitation_sum?.[3] ?? 0;
        const prev3 = (d.daily?.precipitation_sum?.slice(0,3) || []).reduce((a,b)=>a+(b||0),0);
        return { key, label: c.label, today, prev3 };
      } catch(e) { return { key, label: c.label, today: 0, prev3: 0 }; }
    })
  );

  const avg24 = results.reduce((a,r) => a+r.today,0) / results.length;
  const avg72 = results.reduce((a,r) => a+r.prev3,0) / results.length;
  const maxToday = Math.max(...results.map(r => r.today));

  document.getElementById('ws-rows').innerHTML = results.map(r => `
    <div class="ws-row">
      <div>
        <div class="ws-name">${r.label}</div>
        <div style="font-size:8px;color:var(--muted);margin-top:1px">72h: ${r.prev3.toFixed(1)}mm</div>
      </div>
      <div class="ws-bar-wrap"><div class="ws-bar" style="width:${maxToday>0?(r.today/maxToday*100):0}%"></div></div>
      <div class="ws-val">${r.today.toFixed(1)}<span style="font-size:9px;color:var(--muted)">mm</span></div>
    </div>`).join('');

  const mouthToday   = results.find(r=>r.key==='mouth')?.today ?? 0;
  const upstreamAvg  = (results.filter(r=>r.key!=='mouth').reduce((a,r)=>a+r.today,0)) /
                       results.filter(r=>r.key!=='mouth').length;
  const delta = upstreamAvg - mouthToday;
  const deltaText = delta > 5  ? `⚠️ Upstream is <strong>${delta.toFixed(1)}mm heavier</strong> — surge possible in 2–6h` :
                    delta < -5 ? `✅ Mouth is getting more rain than upstream` :
                    `≈ Uniform rainfall across watershed`;

  document.getElementById('ws-avg-line').innerHTML =
    `<strong>Watershed avg 24h: ${avg24.toFixed(1)}mm · 72h avg: ${avg72.toFixed(1)}mm</strong><br><span style="color:var(--ink)">${deltaText}</span>`;

  document.getElementById('ws-delta').innerHTML = `
    <div style="font-size:10px;line-height:1.8;color:var(--muted)">${deltaText}</div>`;

  // Watershed chart
  if (wsChart) wsChart.destroy();
  const ctx = document.getElementById('ws-chart').getContext('2d');
  wsChart = new Chart(ctx, {
    type:'bar',
    data:{
      labels: results.map(r=>r.label.split(' ')[0]),
      datasets:[
        { label:'Today', data:results.map(r=>r.today), backgroundColor:'rgba(72,202,228,0.55)', borderRadius:4 },
        { label:'72h',   data:results.map(r=>r.prev3), backgroundColor:'rgba(45,106,79,0.25)',  borderRadius:4 },
      ]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{ labels:{ font:{family:'DM Mono',size:8}, color:'#5a7a6a' } } },
      scales:{
        x:{ grid:{display:false}, ticks:{font:{family:'DM Mono',size:8},color:'#5a7a6a'} },
        y:{ grid:{color:'rgba(0,0,0,0.05)'}, ticks:{font:{family:'DM Mono',size:8},color:'#5a7a6a'} }
      }
    }
  });

  document.getElementById('ws-loading').style.display  = 'none';
  document.getElementById('ws-content').style.display  = 'block';
}

