async function submitObservation() {
  const btn = document.getElementById('obs-submit');
  const err = document.getElementById('obs-err');
  const ok  = document.getElementById('obs-success');
  err.textContent = '';
  ok.style.display = 'none';

  if (!sbClient) { err.textContent = 'Supabase not connected — see Config tab'; return; }
  const condition   = document.getElementById('obs-condition').value;
  const rainfall    = document.getElementById('obs-rain').value;
  const water_color = document.getElementById('obs-color').value;
  const notes       = document.getElementById('obs-notes').value.trim();
  const observer    = document.getElementById('obs-name').value.trim();
  if (!condition)   { err.textContent = 'Please select a river condition'; return; }

  btn.disabled = true;
  btn.textContent = 'Saving…';
  try {
    await sbClient.from('observations').insert({
      condition, rainfall, water_color, notes, observer,
      flood_score: G.score || null
    });
    ok.style.display = 'block';
    document.getElementById('obs-condition').value = '';
    document.getElementById('obs-rain').value      = '';
    document.getElementById('obs-color').value     = '';
    document.getElementById('obs-notes').value     = '';
    document.getElementById('obs-name').value      = '';
    loadObservations();
  } catch(e) { err.textContent = 'Save failed: ' + e.message; }
  btn.disabled = false;
  btn.textContent = 'Save Observation';
}

