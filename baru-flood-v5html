// ── Multi-model: GFS + ECMWF comparison for past 7 days ──────────────
async function loadMultiModel() {
  const lat = COORDS.mouth.lat, lon = COORDS.mouth.lon;
  const base = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&daily=precipitation_sum&past_days=7&forecast_days=1&timezone=America%2FCosta_Rica`;

  try {
    const [gfsR, ecmwfR] = await Promise.all([
      fetch(base + '&models=gfs_seamless').then(r => r.json()),
      fetch(base + '&models=ecmwf_ifs04').then(r => r.json()),
    ]);

    const labels = (gfsR.daily?.time || []).map(d => {
      const dt = new Date(d + 'T12:00:00');
      return dt.toLocaleDateString('en-US', {month:'short', day:'numeric'});
