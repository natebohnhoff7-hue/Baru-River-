async function loadAll() {
  const now = new Date();
  const month = now.getMonth() + 1;
  const season = getSeason(month);
  const phase  = lunarPhase(lunarAge(now));

  document.getElementById('header-time').textContent =
    now.toLocaleString('en-US', { weekday:'short', month:'short', day:'numeric',
                                   hour:'numeric', minute:'2-digit', timeZone:'America/Costa_Rica' });
  document.getElementById('season-badge').textContent =
    `${season.emoji} ${season.name} · ${now.toLocaleString('en-US',{month:'long'})}`;

  // Fetch mouth weather (OpenMeteo)
  const weatherUrl =
    `https://api.open-meteo.com/v1/forecast?latitude=${COORDS.mouth.lat}&longitude=${COORDS.mouth.lon}` +
    `&current=temperature_2m,relative_humidity_2m,precipitation,wind_speed_10m` +
    `&hourly=soil_moisture_0_to_1cm` +
    `&daily=precipitation_sum,uv_index_max` +
    `&past_days=3&forecast_days=7&timezone=America%2FCosta_Rica`;

  let weather = {}, tideM = null;

  // ── 1. OpenMeteo weather (free, no key, always works) ──
  try {
    const r = await fetch(weatherUrl);
    if (r.ok) weather = await r.json();
    else console.warn('OpenMeteo HTTP', r.status);
  } catch(e) { console.warn('OpenMeteo fetch failed', e); }

  // ── 2. Harmonic tide model — 5 constituents, calibrated Bahía Uvita ──
  // Constituents: M2 (principal lunar semidiurnal), S2 (principal solar semidiurnal),
  // N2 (larger lunar elliptic), K1 (lunisolar diurnal), O1 (principal lunar diurnal)
  // Reference epoch: 2000-01-01 00:00 UTC (J2000)
  // Amplitudes and phases calibrated to NOAA/IHO data for Costa Rica Pacific coast
  tideM = harmonicTide(now);

  // ── Parse weather ──
  const cur    = weather?.current   || {};
  const daily  = weather?.daily     || {};
  const hourly = weather?.hourly    || {};

  // past_days=3 → indices [0,1,2] = 3/2/1 days ago, [3] = today
  // but OpenMeteo daily starts at index 0 = 3 days ago
  // today is index 3
  const todayIdx = 3;
  const rain24 = daily.precipitation_sum?.[todayIdx] ?? 0;
  // 72h = yesterday + day before + day before that (indices 1,2,3)
  const rain72 = [1,2,3].reduce((a,i) => a + (daily.precipitation_sum?.[i] ?? 0), 0);
  const soilArr = hourly.soil_moisture_0_to_1cm || [];
  // grab most recent hour available (last element)
  const soilVal = soilArr.length ? soilArr[soilArr.length - 1] : null;

  const rainR  = scoreRain(rain24, rain72);
  const soilR  = scoreSoil(soilVal);
  const tideR  = scoreTide(tideM ?? 1.0);
  const score  = calcRisk(rainR, phase.risk, soilR, tideR, season.base);
  const level  = riskLevel(score);

  G = { score, level, rain24, rain72, soilVal, tideM, phase, season, rainR, soilR, tideR,
        daily, weather, now, month };

  // ─── Update ring ───
  const pct = Math.round(score * 100);
  const circ = 364.4;
  document.getElementById('ring-arc').style.strokeDashoffset = circ - circ * score;
  document.getElementById('ring-arc').setAttribute('stroke', level.color);
  document.getElementById('ring-pct').textContent  = pct + '%';
  document.getElementById('ring-pct').style.color  = level.color;
  document.getElementById('ring-label').textContent = level.label;
  document.getElementById('ring-label').style.color = level.color;

  // chips
  document.getElementById('risk-chips').innerHTML =
    `<span class="chip" style="color:${level.color}">${level.label}</span>
     <span class="chip" style="color:var(--teal)">${phase.emoji} ${phase.name}</span>
     <span class="chip" style="color:var(--muted)">${season.emoji} ${season.name}</span>`;

  // ─── Overview stats ───
  document.getElementById('ov-rain24').textContent = rain24.toFixed(1);
  document.getElementById('ov-rain72').textContent = rain72.toFixed(1);
  document.getElementById('ov-temp').textContent   = cur.temperature_2m?.toFixed(1) ?? '—';
  document.getElementById('ov-humid').textContent  = cur.relative_humidity_2m ?? '—';
  document.getElementById('ov-wind').textContent   = cur.wind_speed_10m?.toFixed(0) ?? '—';
  document.getElementById('ov-soil').textContent   = soilVal?.toFixed(3) ?? '—';
  document.getElementById('ov-tide').textContent   = tideM?.toFixed(2) ?? '—';

  drawMoon(phase);

  // ─── Factor bars ───
  const factors = [
    { label:`Rainfall  (24h: ${rain24.toFixed(1)}mm / 72h: ${rain72.toFixed(1)}mm)`, val: rainR,    w:'38%', color: 'var(--teal)' },
    { label:`Lunar — ${phase.name}`,                                                  val: phase.risk,w:'22%', color: '#9b59b6'   },
    { label:`Soil Moisture (${soilVal?.toFixed(3) ?? '—'} m³/m³)`,                  val: soilR,    w:'18%', color: 'var(--sand)'},
    { label:`Tide Height (${tideM?.toFixed(2) ?? '~'} m)`,                            val: tideR,    w:'14%', color: 'var(--teal-light)'},
    { label:`Season Baseline — ${season.name}`,                                       val: season.base,w:'8%',color: 'var(--green)'},
  ];
  document.getElementById('factor-bars').innerHTML = factors.map(f => `
    <div class="factor-row">
      <div class="factor-meta"><span>${f.label}</span><span style="color:var(--ink)">${(f.val*100).toFixed(0)}% · ×${f.w}</span></div>
      <div class="factor-track"><div class="factor-fill" style="width:${f.val*100}%;background:${f.color}"></div></div>
    </div>`).join('');

  document.getElementById('score-formula').innerHTML =
    `FORMULA: Rain×0.38 + Lunar×0.22 + Soil×0.18 + Tide×0.14 + Season×0.08<br>` +
    `= ${(rainR*0.38).toFixed(3)} + ${(phase.risk*0.22).toFixed(3)} + ${(soilR*0.18).toFixed(3)} + ${(tideR*0.14).toFixed(3)} + ${(season.base*0.08).toFixed(3)}<br>` +
    `= <span style="color:${level.color};font-weight:500">${score.toFixed(3)} → ${level.label}</span>`;

  document.getElementById('overview-loading').style.display  = 'none';
  document.getElementById('overview-content').style.display  = 'block';

  // ─── 7-day forecast ───
  buildForecast();
  buildTideChart(now);

  // ─── Log to Supabase ───
  if (sbClient) logReading();
}

