function buildForecast() {
  const daily = G.daily;
  if (!daily.time) return;
  const todayIdx = 3;
  const days = daily.time.slice(todayIdx, todayIdx+7);
  const rains = daily.precipitation_sum?.slice(todayIdx, todayIdx+7) || [];
  const labels = ['Today','Tomorrow'];
  const DAYNAMES = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

  const strip = days.map((date, i) => {
    const d = new Date(date + 'T12:00:00-06:00');
    const r = rains[i] || 0;
    const phase = lunarPhase(lunarAge(d));
    const rR = scoreRain(r, r * 2);
    const s = calcRisk(rR, phase.risk, G.soilR, 0.3, G.season.base);
    const lv = riskLevel(s);
    const name = i < 2 ? labels[i] : DAYNAMES[d.getDay()];
    return `<div class="fc-day">
      <div class="fc-day-name">${name}</div>
      <div class="fc-score" style="color:${lv.color}">${Math.round(s*100)}%</div>
      <div class="fc-rain">💧${r.toFixed(0)}mm</div>
    </div>`;
  }).join('');

  document.getElementById('forecast-strip-wrap').innerHTML =
    `<div class="forecast-strip">${strip}</div>`;

  // Rain chart
  if (rainChart) rainChart.destroy();
  const ctx = document.getElementById('rain-chart').getContext('2d');
  rainChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: days.map((d,i) => i === 0 ? 'Today' : i === 1 ? 'Tmrw' : DAYNAMES[new Date(d+'T12:00:00').getDay()]),
      datasets: [{ label:'Rain mm', data: rains, backgroundColor: 'rgba(72,202,228,0.5)', borderColor:'#48cae4', borderWidth:1, borderRadius:4 }]
    },
    options: {
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{display:false} },
      scales:{
        x:{ grid:{display:false}, ticks:{font:{family:'DM Mono',size:9},color:'#5a7a6a'} },
        y:{ grid:{color:'rgba(0,0,0,0.05)'}, ticks:{font:{family:'DM Mono',size:9},color:'#5a7a6a'} }
      }
    }
  });
}

