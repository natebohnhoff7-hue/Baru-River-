// ── NASA POWER — satellite corrected precipitation past 30 days ───────
async function loadNASAPower() {
  const lat = COORDS.mouth.lat, lon = COORDS.mouth.lon;
  const end = new Date();
  const start = new Date(end);
  start.setDate(start.getDate() - 30);

  const fmt = d => d.toISOString().split('T')[0].replace(/-/g, '');
  const url = `https://power.larc.nasa.gov/api/temporal/daily/point?parameters=PRECTOTCORR,RH2M,T2M,WS10M&community=ag&longitude=${lon}&latitude=${lat}&start=${fmt(start)}&end=${fmt(end)}&format=JSON`;

  try {
    const r = await fetch(url);
    const d = await r.json();
    const precip = d.properties?.parameter?.PRECTOTCORR || {};
    const rh     = d.properties?.parameter?.RH2M        || {};
    const temp   = d.properties?.parameter?.T2M         || {};

    const dates  = Object.keys(precip).sort();
    const values = dates.map(k => Math.max(0, precip[k] === -999 ? 0 : precip[k]));
    const total  = values.reduce((a,b) => a+b, 0);
    const maxDay = Math.max(...values);
    const maxDate = dates[values.indexOf(maxDay)];
    const avgTemp = Object.values(temp).filter(v=>v!==-999).reduce((a,b,_,arr)=>a+b/arr.length,0);
    const avgRH   = Object.values(rh).filter(v=>v!==-999).reduce((a,b,_,arr)=>a+b/arr.length,0);

    // Format max date
    const maxDt = new Date(maxDate.slice(0,4)+'-'+maxDate.slice(4,6)+'-'+maxDate.slice(6,8)+'T12:00:00');
    const maxLabel = maxDt.toLocaleDateString('en-US',{month:'short',day:'numeric'});

    document.getElementById('hist-nasa-stats').innerHTML = `
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:6px;margin-bottom:8px">
        <div style="text-align:center;background:rgba(72,202,228,0.10);border-radius:8px;padding:8px">
          <div style="font-family:'Playfair Display',serif;font-size:18px;color:var(--teal)">${total.toFixed(0)}</div>
          <div style="font-size:7.5px;color:var(--muted)">mm total</div>
        </div>
        <div style="text-align:center;background:rgba(192,57,43,0.08);border-radius:8px;padding:8px">
          <div style="font-family:'Playfair Display',serif;font-size:18px;color:#c0392b">${maxDay.toFixed(1)}</div>
          <div style="font-size:7.5px;color:var(--muted)">max day</div>
          <div style="font-size:7px;color:var(--muted)">${maxLabel}</div>
        </div>
        <div style="text-align:center;background:rgba(233,168,37,0.10);border-radius:8px;padding:8px">
          <div style="font-family:'Playfair Display',serif;font-size:18px;color:var(--amber)">${avgTemp.toFixed(1)}°</div>
          <div style="font-size:7.5px;color:var(--muted)">avg temp</div>
        </div>
        <div style="text-align:center;background:rgba(45,106,79,0.08);border-radius:8px;padding:8px">
          <div style="font-family:'Playfair Display',serif;font-size:18px;color:var(--green)">${avgRH.toFixed(0)}%</div>
          <div style="font-size:7.5px;color:var(--muted)">avg RH</div>
        </div>
      </div>`;

    const chartLabels = dates.map(k => {
      const dt = new Date(k.slice(0,4)+'-'+k.slice(4,6)+'-'+k.slice(6,8)+'T12:00:00');
      return dt.toLocaleDateString('en-US',{month:'short',day:'numeric'});
    });

    if (histNasaChart) histNasaChart.destroy();
    const ctx = document.getElementById('hist-nasa-chart').getContext('2d');
    histNasaChart = new Chart(ctx, {
      type:'bar',
      data:{
        labels: chartLabels,
        datasets:[{
          label:'NASA POWER mm/day',
          data: values,
          backgroundColor: values.map(v =>
            v > 50 ? 'rgba(192,57,43,0.7)' :
            v > 20 ? 'rgba(233,168,37,0.6)' :
            'rgba(72,202,228,0.5)'
          ),
          borderRadius:3,
        }]
      },
      options:{
        responsive:true, maintainAspectRatio:false,
        plugins:{ legend:{display:false} },
        scales:{
          x:{ grid:{display:false}, ticks:{font:{family:'DM Mono',size:7},color:'#5a7a6a',maxRotation:45,maxTicksLimit:10} },
          y:{ grid:{color:'rgba(0,0,0,0.05)'}, ticks:{font:{family:'DM Mono',size:8},color:'#5a7a6a'} }
        }
      }
    });

    document.getElementById('hist-nasa-loading').style.display = 'none';
    document.getElementById('hist-nasa-content').style.display = 'block';
  } catch(e) {
    document.getElementById('hist-nasa-loading').innerHTML =
      `<div class="err">NASA POWER unavailable: ${e.message}</div>`;
  }
}

// ── 30-year seasonal climatology chart ───────────────────────────────
function buildSeasonalChart() {
  const now = new Date();
  const currentMonth = now.getMonth(); // 0-indexed
  const colors = CLIMATOLOGY.rain.map((_, i) => {
    if (i === currentMonth) return 'rgba(45,106,79,0.85)';
    if (CLIMATOLOGY.season[i] === 'peak') return 'rgba(192,57,43,0.55)';
    if (CLIMATOLOGY.season[i] === 'wet')  return 'rgba(72,202,228,0.50)';
    if (CLIMATOLOGY.season[i] === 'trans')return 'rgba(233,168,37,0.50)';
    return 'rgba(212,169,106,0.40)';
  });

  if (histSeasonalChart) histSeasonalChart.destroy();
  const ctx = document.getElementById('hist-seasonal-chart').getContext('2d');
  histSeasonalChart = new Chart(ctx, {
    type:'bar',
    data:{
      labels: CLIMATOLOGY.labels,
      datasets:[{
        label:'Avg mm',
        data: CLIMATOLOGY.rain,
        backgroundColor: colors,
        borderRadius:4,
      }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{display:false} },
      scales:{
        x:{ grid:{display:false}, ticks:{font:{family:'DM Mono',size:9},color:'#5a7a6a'} },
        y:{ grid:{color:'rgba(0,0,0,0.05)'}, ticks:{font:{family:'DM Mono',size:8},color:'#5a7a6a'} }
      }
    }
  });

  const currentRain = CLIMATOLOGY.rain[currentMonth];
  const monthName   = CLIMATOLOGY.labels[currentMonth];
  const season      = CLIMATOLOGY.season[currentMonth];
  const seasonNames = { dry:'Dry Season', trans:'Transition', wet:'Green Season', peak:'Peak Wet' };
  document.getElementById('hist-seasonal-label').innerHTML =
    `<strong style="color:var(--green-dark)">${monthName}</strong> avg: ${currentRain}mm · ${seasonNames[season]} · Current month highlighted green`;
}

// ── Extended 16-day forecast all 3 watershed points ──────────────────
async function loadExtendedForecast() {
  try {
    const results = await Promise.all(
      Object.entries(COORDS).map(async ([key, c]) => {
        const url = `https://api.open-meteo.com/v1/forecast?latitude=${c.lat}&longitude=${c.lon}` +
          `&daily=precipitation_sum,precipitation_probability_max` +
          `&forecast_days=16&timezone=America%2FCosta_Rica`;
        const r = await fetch(url);
        const d = await r.json();
        return { key, label: c.label.split(' ')[0], data: d };
      })
    );

    const times = results[0].data?.daily?.time || [];
    const DAYNAMES = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    const labels = times.map(t => {
      const d = new Date(t + 'T12:00:00');
      return DAYNAMES[d.getDay()] + ' ' + (d.getMonth()+1) + '/' + d.getDate();
    });

    const datasets = results.map((r, i) => {
      const colors = ['rgba(45,106,79', 'rgba(13,127,127', 'rgba(212,169,106'];
      return {
        label: r.label,
        data: r.data?.daily?.precipitation_sum || [],
        backgroundColor: colors[i] + ',0.45)',
        borderColor: colors[i] + ',0.8)',
        borderWidth: 1,
        borderRadius: 3,
      };
    });

    // Warning if any point shows >50mm in next 5 days
    const mouthNext5 = (results[0].data?.daily?.precipitation_sum || []).slice(0,5);
    const upstreamNext5 = [
      ...(results[1].data?.daily?.precipitation_sum || []).slice(0,5),
      ...(results[2].data?.daily?.precipitation_sum || []).slice(0,5),
    ];
    const maxMouth    = Math.max(...mouthNext5);
    const maxUpstream = Math.max(...upstreamNext5);

    let warningHtml = '';
    if (maxUpstream > 80) {
      warningHtml = `<div style="background:rgba(192,57,43,0.10);border:1px solid rgba(192,57,43,0.30);border-radius:8px;padding:10px;color:#c0392b;font-size:9px;line-height:1.7">
        ⚠️ <strong>HEAVY RAIN FORECAST UPSTREAM</strong> — ${maxUpstream.toFixed(0)}mm expected in Platanillo/Tinamastes within 5 days. High flood risk. Monitor closely.
      </div>`;
    } else if (maxUpstream > 40) {
      warningHtml = `<div style="background:rgba(233,168,37,0.10);border:1px solid rgba(233,168,37,0.30);border-radius:8px;padding:10px;color:#8a6010;font-size:9px;line-height:1.7">
        🌧 Moderate rain forecast upstream (${maxUpstream.toFixed(0)}mm) — river may rise. Watch conditions.
      </div>`;
    } else {
      warningHtml = `<div style="font-size:9px;color:var(--green);padding:6px 0">✅ No significant rainfall forecast upstream in next 5 days.</div>`;
    }

    if (histExtChart) histExtChart.destroy();
    const ctx = document.getElementById('hist-extended-chart').getContext('2d');
    histExtChart = new Chart(ctx, {
      type:'bar',
      data:{ labels, datasets },
      options:{
        responsive:true, maintainAspectRatio:false,
        plugins:{ legend:{ labels:{ font:{family:'DM Mono',size:8}, color:'#5a7a6a' } } },
        scales:{
          x:{ grid:{display:false}, ticks:{font:{family:'DM Mono',size:7},color:'#5a7a6a',maxRotation:45,maxTicksLimit:8} },
          y:{ grid:{color:'rgba(0,0,0,0.05)'}, ticks:{font:{family:'DM Mono',size:8},color:'#5a7a6a'} }
        }
      }
    });

    document.getElementById('hist-extended-warning').innerHTML = warningHtml;
    document.getElementById('hist-extended-loading').style.display = 'none';
    document.getElementById('hist-extended-content').style.display = 'block';

  } catch(e) {
    document.getElementById('hist-extended-loading').innerHTML =
      `<div class="err">Extended forecast failed: ${e.message}</div>`;
  }
}

